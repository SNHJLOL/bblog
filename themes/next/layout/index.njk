{% extends '_layout.njk' %}
{% import '_macro/sidebar.njk' as sidebar_template with context %}

{% block title %}{{ title }}{% if theme.index_with_subtitle and subtitle %} - {{ subtitle }}{% endif %} {% endblock %}

{% block class %}home-page{% endblock %}

{% block content %}

<div class="home-content">
  <div class="home-header">
    <div class="home-title">二十六</div>
  </div>
  <div class="home-description">
    一个普普通通的打工人
  </div>
  <div class="home-links">
    <a href="/about/" class="home-link">about</a>
  </div>
</div>

<style>
/* 全局透明背景 */
.home-page {
  background: transparent !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #fff !important;
}

/* 主体容器 */
.home-page .main-inner {
  max-width: 800px;
  margin: 0 auto;
  padding: 8vh 20px;
  text-align: center;
  background: transparent !important;
  box-shadow: none !important;
  border: none !important;
}

/* 主页卡片：透明毛玻璃 + 直角 */
.home-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 65vh;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(12px) saturate(180%);
  -webkit-backdrop-filter: blur(12px) saturate(180%);
  border-radius: 0;          /* 直角 */
  border: 1px solid rgba(255, 255, 255, 0.2);
  padding: 60px 40px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
}

.home-header {
  margin-bottom: 28px;
}

.home-title {
  font-size: 28px;
  font-weight: 700;
  color: #fff;           /* 白色 */
  letter-spacing: 1px;
}

.home-description {
  font-size: 16px;
  line-height: 1.75;
  color: #fff;           /* 白色 */
  max-width: 580px;
  margin-bottom: 44px;
  opacity: 0.9;
}

.home-links {
  margin-top: 10px;
}

/* 按钮：直角 + 白色文字 */
.home-link {
  display: inline-block;
  padding: 12px 28px;
  color: #fff;           /* 白色 */
  text-decoration: none;
  font-size: 15px;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 0;      /* 直角 */
  transition: all 0.3s ease;
}

.home-link:hover {
  background: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.5);
  transform: translateY(-2px);
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

/* 导航栏透明 + 白色文字 */
.home-page .header,
.home-page .site-nav,
.home-page .main-menu {
  background: transparent !important;
  box-shadow: none !important;
  border: none !important;
}

.home-page .menu-item a {
  color: #fff !important;
  font-weight: 500;
}

.home-page .headband {
  display: none !important;
}

.home-page .header {
  padding: 30px 0;
  border-bottom: none !important;
}

/* 侧边栏：直角 + 透明 */
.home-page .sidebar {
  background: rgba(255, 255, 255, 0.1) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  border-radius: 0 !important;   /* 直角 */
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
  padding: 24px !important;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08) !important;
  color: #fff !important;
}

/* 天气组件直角 */
.home-page .weather-widget {
  background: rgba(255, 255, 255, 0.15) !important;
  backdrop-filter: blur(8px) !important;
  -webkit-backdrop-filter: blur(8px) !important;
  border-radius: 0 !important;   /* 直角 */
  border: 1px solid rgba(255, 255, 255, 0.25) !important;
  color: #fff !important;
}

/* 移动端 */
@media (max-width: 768px) {
  .home-content {
    padding: 40px 24px;
    min-height: 60vh;
  }
  .home-title {
    font-size: 24px;
  }
  .home-description {
    font-size: 15px;
  }
  .home-page .main-inner {
    padding: 4vh 16px;
  }
}
</style>

{% endblock %}

{% block sidebar %}
  {{ sidebar_template.render(false) }}
{% endblock %}