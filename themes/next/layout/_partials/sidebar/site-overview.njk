<div class="site-author animated" itemprop="author" itemscope itemtype="http://schema.org/Person">
  <img class="site-author-image" itemprop="image" alt="{{ author }}" src="/images/avatar.jpg">
  <p class="site-author-name" itemprop="name">{{ author }}</p>
</div>

{%- if theme.chat.enable and (theme.chatra.enable or theme.tidio.enable) %}
  <div class="sidebar-button animated">
    <button>
      {%- if theme.chat.icon %}<i class="{{ theme.chat.icon }}"></i>{% endif %}
      {{ __('widget.chat') }}
    </button>
  </div>
{%- endif %}

{%- if theme.social %}
  <div class="links-of-author animated">
    {%- for name, link in theme.social %}
      <span class="links-of-author-item">
        {%- set sidebarURL = link.split('||')[0] | trim %}
        {%- set sidebarIcon = '<i class="' + link.split('||')[1] | trim + ' fa-fw"></i>' if theme.social_icons.enable and link.split('||')[1] else '' %}
        {%- set sidebarText = '' if (theme.social_icons.enable and theme.social_icons.icons_only) else name %}
        {{ next_url(sidebarURL, sidebarIcon + sidebarText, {title: name + ' → ' + sidebarURL, rel: 'noopener me'}) }}
      </span>
    {%- endfor %}
  </div>
{%- endif %}

{%- if theme.creative_commons.license and theme.creative_commons.sidebar %}
  <div class="cc-license animated" itemprop="license">
    {%- set ccImage = '<img src="' + theme.vendors.creative_commons.url + '" alt="Creative Commons">' %}
    {{ next_url(ccURL, ccImage, {class: 'cc-opacity'}) }}
  </div>
{%- endif %}

{%- if theme.weather.enable %}
  <div class="weather-widget animated">
    <div class="weather-title">
      <i class="fa fa-cloud"></i> {{ __('widget.weather') }}
    </div>
    <div id="weather-content">
      <div class="weather-loading">
        <i class="fa fa-spinner fa-spin"></i> {{ __('widget.weather.loading') }}
      </div>
    </div>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const weatherContent = document.getElementById('weather-content');
      
      function getWeather(lat, lon) {
        const apiKey = '{{ theme.weather.api_key }}';
        const iconStyle = {{ theme.weather.icon_style }};
        const unit = '{{ theme.weather.temperature_unit }}';
        
        // 先通过地理编码API获取城市名
        fetch(`https://my487tqyq4.re.qweatherapi.com/geo/v2/city/lookup?gzip=n&location=${lon},${lat}&key=${apiKey}`)
          .then(response => response.json())
          .then(locationData => {
            let city = '{{ theme.weather.default_city }}';
            if (locationData.code === '200' && locationData.location && locationData.location.length > 0) {
              const location = locationData.location[0];
              city = `${location.adm1}${location.adm2}${location.name}`;
            }
            
            // 先显示城市名和加载状态
            weatherContent.innerHTML = `
              <div class="weather-info">
                <div class="weather-city">${city}</div>
                <div class="weather-loading">
                  <i class="fa fa-spinner fa-spin"></i> 获取天气信息中...
                </div>
              </div>
            `;
            
            // 再查询天气
            return fetch(`https://my487tqyq4.re.qweatherapi.com/v7/weather/now?gzip=n&location=${lon},${lat}&key=${apiKey}`)
              .then(response => response.json())
              .then(weatherData => {
                return { weatherData, city };
              });
          })
          .then(({ weatherData, city }) => {
            if (weatherData.code === '200' && weatherData.now) {
              const weather = weatherData.now;
              const temp = weather.temp;
              const condition = weather.text;
              const icon = weather.icon;
              const humidity = weather.humidity;
              const windDir = weather.windDir;
              const windScale = weather.windScale;
              
              // 获取未来三天天气预报
              fetch(`https://my487tqyq4.re.qweatherapi.com/v7/weather/3d?gzip=n&location=${lon},${lat}&key=${apiKey}`)
                .then(response => response.json())
                .then(forecastData => {
                  let forecastHtml = '';
                  if (forecastData.code === '200' && forecastData.daily) {
                    // 只显示未来三天的预报
                    const threeDayForecast = forecastData.daily.slice(0, 3);
                    forecastHtml = `
                      <div class="weather-forecast">
                        ${threeDayForecast.map(day => `
                          <div class="forecast-item">
                            <div class="forecast-date">${day.fxDate.substring(5)}</div>
                            <div class="forecast-condition">${day.textDay}</div>
                            <img class="forecast-icon" src="/icon/${day.iconDay}.svg" alt="${day.textDay}">
                            <div class="forecast-temp">${day.tempMin}°/${day.tempMax}°</div>
                          </div>
                        `).join('')}
                      </div>
                    `;
                  }
                  
                  weatherContent.innerHTML = `
                    <div class="weather-info">
                      <div class="weather-city">${city}</div>
                      <div class="weather-main">
                        <div class="weather-desc">${condition}</div>
                        <div class="weather-temp">${temp}°${unit.toUpperCase()}</div>
                      </div>
                      <div class="weather-details">
                        <span>湿度: ${humidity}%</span>
                        <span>风向: ${windDir}</span>
                        <span>风力: ${windScale}级</span>
                      </div>
                      ${forecastHtml}
                    </div>
                  `;
                })
                .catch(error => {
                  console.error('Forecast API error:', error);
                  // 即使获取预报失败，也要显示当前天气
                  weatherContent.innerHTML = `
                    <div class="weather-info">
                      <div class="weather-city">${city}</div>
                      <div class="weather-main">
                        <div class="weather-desc">${condition}</div>
                        <div class="weather-temp">${temp}°${unit.toUpperCase()}</div>
                      </div>
                      <div class="weather-details">
                        <span>湿度: ${humidity}%</span>
                        <span>风向: ${windDir}</span>
                        <span>风力: ${windScale}级</span>
                      </div>
                      <div class="weather-error">获取天气预报失败: ${error.message}</div>
                    </div>
                  `;
                });
            } else {
              const errorCode = weatherData.code || '未知错误';
              weatherContent.innerHTML = `
                <div class="weather-info">
                  <div class="weather-city">${city}</div>
                  <div class="weather-error">获取天气失败: ${errorCode}</div>
                </div>
              `;
            }
          })
          .catch(error => {
            console.error('Weather API error:', error);
            weatherContent.innerHTML = `<div class="weather-error">获取天气失败: ${error.message}</div>`;
          });
      }
      
      function getDefaultWeather() {
        const defaultCity = '{{ theme.weather.default_city }}';
        const apiKey = '{{ theme.weather.api_key }}';
        
        fetch(`https://my487tqyq4.re.qweatherapi.com/v7/location/search?gzip=n&keywords=${defaultCity}&key=${apiKey}`)
          .then(response => response.json())
          .then(data => {
            if (data.code === '200' && data.location && data.location.length > 0) {
              const location = data.location[0];
              getWeather(location.lat, location.lon);
            } else {
              const errorCode = data.code || '未知错误';
              weatherContent.innerHTML = `<div class="weather-error">无法获取默认城市天气: ${errorCode}</div>`;
            }
          })
          .catch(error => {
            console.error('Location API error:', error);
            weatherContent.innerHTML = `<div class="weather-error">获取默认城市天气失败</div>`;
          });
      }
      
      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
          position => {
            getWeather(position.coords.latitude, position.coords.longitude);
          },
          error => {
            console.error('Geolocation error:', error);
            getDefaultWeather();
          }
        );
      } else {
        getDefaultWeather();
      }
    });
  </script>
{%- endif %}

<style>
  /* 侧边栏整体样式 */
  .sidebar {
    background-color: #000;
    border-radius: 8px;
    padding: 20px;
  }
  
  /* 作者信息样式 */
  .site-author {
    text-align: center;
    padding: 15px 0;
  }
  
  .site-author-image {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    margin-bottom: 12px;
    border: 3px solid #E6397C;
    box-shadow: 0 0 10px rgba(230, 57, 124, 0.5);
  }
  
  .site-author-name {
    font-size: 16px;
    font-weight: bold;
    color: #E6397C;
    margin-bottom: 8px;
  }
  
  .site-description {
    font-size: 13px;
    color: #E6397C;
    margin-bottom: 15px;
  }
  
  /* 社交链接样式 */
  .links-of-author {
    margin-top: 15px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    padding: 0 10px;
  }
  
  .links-of-author-item {
    display: flex;
    justify-content: center;
  }
  
  .links-of-author-item a {
    color: #E6397C;
    font-size: 12px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    white-space: nowrap;
  }
  
  .links-of-author-item a:hover {
    color: #fff;
  }
  
  .links-of-author-item i {
    margin-right: 5px;
  }
  
  /* 天气组件样式 */
  .weather-widget {
    margin-top: 20px;
    padding: 15px;
    background: rgba(230, 57, 124, 0.1);
    border-radius: 8px;
    border: 1px solid rgba(230, 57, 124, 0.3);
  }
  
  .weather-title {
    font-size: 15px;
    font-weight: bold;
    margin-bottom: 12px;
    color: #E6397C;
  }
  
  .weather-loading {
    text-align: center;
    padding: 15px 0;
    color: #E6397C;
  }
  
  .weather-error {
    text-align: center;
    padding: 15px 0;
    color: #E6397C;
  }
  
  .weather-info {
    text-align: center;
  }
  
  .weather-city {
    font-size: 13px;
    margin-bottom: 12px;
    color: #E6397C;
  }
  
  .weather-main {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
    text-align: center;
  }
  
  .weather-temp {
    font-size: 22px;
    font-weight: bold;
    color: #E6397C;
    flex-shrink: 0;
    margin-left: 10px;
  }
  
  .weather-desc {
    font-size: 22px;
    color: #E6397C;
    flex-shrink: 0;
    margin-right: 10px;
  }
  
  .weather-details {
    font-size: 11px;
    color: #E6397C;
    line-height: 1.4;
  }
  
  .weather-details span {
    display: block;
  }
  
  .weather-forecast {
    margin-top: 12px;
    border-top: 1px solid rgba(230, 57, 124, 0.2);
    padding-top: 12px;
  }
  
  .forecast-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    border-bottom: 1px solid rgba(230, 57, 124, 0.1);
  }
  
  .forecast-item:last-child {
    border-bottom: none;
  }
  
  .forecast-date {
    width: 40px;
    font-size: 11px;
    color: #E6397C;
  }
  
  .forecast-condition {
    flex: 1;
    font-size: 11px;
    color: #E6397C;
    text-align: center;
  }
  
  .forecast-icon {
    width: 20px;
    height: 20px;
    margin: 0 5px;
  }
  
  .forecast-temp {
    width: 60px;
    font-size: 11px;
    color: #E6397C;
    text-align: right;
  }
  
  /* 侧边栏导航样式 */
  .sidebar-nav {
    margin-bottom: 20px;
  }
  
  .sidebar-nav-item {
    margin-bottom: 5px;
  }
  
  .sidebar-nav-item a {
    display: block;
    padding: 8px 12px;
    color: #E6397C;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  
  .sidebar-nav-item a:hover {
    background-color: rgba(230, 57, 124, 0.2);
  }
  
  .sidebar-nav-item.active a {
    background-color: #E6397C;
    color: #1A1A1D;
  }
</style>
