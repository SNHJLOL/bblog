<div class="widget weather">
  <div class="widget-title">
    <i class="fas fa-cloud-sun"></i>
    <span>天气</span>
  </div>
  <div class="widget-content">
    <div id="weather-widget" class="weather-content">
      <div class="loading">加载中...</div>
    </div>
  </div>
</div>

<script>
  // 天气组件初始化函数
  function initWeatherWidget() {
    const weatherWidget = document.getElementById('weather-widget');
    if (!weatherWidget) return;
    
    // 硬编码配置值，确保组件能正常显示
    const apiKey = 'cd2881ae1f584ba2a11b77136fb610ec';
    const defaultCity = 'Beijing';
    const temperatureUnit = 'c';
    
    // 获取天气数据
    function getWeatherData(city, cityName = '') {
      weatherWidget.innerHTML = '<div class="loading">加载中...</div>';
      
      // 并行获取当前天气和未来天气预报
      const nowUrl = `https://my487tqyq4.re.qweatherapi.com/v7/weather/now?key=${apiKey}&location=${city}&lang=zh`;
      const forecastUrl = `https://my487tqyq4.re.qweatherapi.com/v7/weather/7d?key=${apiKey}&location=${city}&lang=zh`;
      
      Promise.all([
        fetch(nowUrl).then(response => response.json()),
        fetch(forecastUrl).then(response => response.json())
      ])
      .then(([nowData, forecastData]) => {
        if (nowData.code === '200' && forecastData.code === '200') {
          renderWeather(nowData, forecastData, cityName);
        } else {
          weatherWidget.innerHTML = '<div class="error">天气数据获取失败</div>';
        }
      })
      .catch(error => {
        console.error('Error fetching weather data:', error);
        weatherWidget.innerHTML = '<div class="error">天气数据获取失败</div>';
      });
    }
    
    // 渲染天气信息
    function renderWeather(nowData, forecastData, cityName) {
      const now = nowData.now;
      const forecast = forecastData.daily.slice(0, 3); // 只取今天、明天、后天
      
      // 格式化日期
      function formatDate(dateStr) {
        const date = new Date(dateStr);
        const today = new Date();
        const tomorrow = new Date(today);
        tomorrow.setDate(tomorrow.getDate() + 1);
        
        if (date.toDateString() === today.toDateString()) {
          return '今天';
        } else if (date.toDateString() === tomorrow.toDateString()) {
          return '明天';
        } else {
          return `${date.getMonth() + 1}/${date.getDate()}`;
        }
      }
      
      const weatherHtml = `
        <div class="weather-main">
          ${cityName ? `<div class="city-name">${cityName}</div>` : ''}
          <div class="current-temp">${now.temp}°${temperatureUnit === 'c' ? 'C' : 'F'}</div>
          <div class="weather-desc">${now.text}</div>
          <div class="weather-info">
            <span>湿度: ${now.humidity}%</span>
            <span>风速: ${now.windSpeed}km/h</span>
          </div>
        </div>
        <div class="weather-forecast">
          ${forecast.map(day => `
            <div class="forecast-day">
              <div class="forecast-date">${formatDate(day.fxDate)}</div>
              <div class="forecast-text">${day.textDay}</div>
              <div class="forecast-temp">
                <span class="temp-max">${day.tempMax}°</span>
                <span class="temp-min">${day.tempMin}°</span>
              </div>
            </div>
          `).join('')}
        </div>
      `;
      weatherWidget.innerHTML = weatherHtml;
    }
    
    // 优先使用地理位置
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        function(position) {
          const lat = position.coords.latitude;
          const lon = position.coords.longitude;
          const geoUrl = `https://my487tqyq4.re.qweatherapi.com/geo/v2/city/lookup?key=${apiKey}&location=${lon},${lat}`;
          fetch(geoUrl)
            .then(response => response.json())
            .then(data => {
              if (data.code === '200' && data.location.length > 0) {
                getWeatherData(data.location[0].id, data.location[0].name);
              } else {
                getWeatherData(defaultCity, '北京');
              }
            })
            .catch(() => {
              getWeatherData(defaultCity, '北京');
            });
        },
        function() {
          getWeatherData(defaultCity, '北京');
        }
      );
    } else {
      getWeatherData(defaultCity, '北京');
    }
  }
  
  // 当DOM加载完成时初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWeatherWidget);
  } else {
    initWeatherWidget();
  }
  
  // 当PJAX完成时重新初始化，确保每次切换标签都刷新天气
  document.addEventListener('pjax:complete', initWeatherWidget);
</script>

